# .env.example
# Gemini API Key (Required)
GEMINI_API_KEY=

# Email Configuration (Optional - will log to console if missing)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
ADMIN_EMAIL=

# Firebase Configuration (Required for server-side DB access)
# For local dev, you can use a service account JSON or environment variables
FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=
